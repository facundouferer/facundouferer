---
import { getCollection } from 'astro:content';
import ArticlesCatalog from '../../components/ArticlesCatalog.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { buildCollectionPageSchemas } from '../../seo/schema';
import { getArticlesForLocale } from '../../utils/articles';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const articles = getArticlesForLocale(await getCollection('articles'), 'es', 'en');
const schema = buildCollectionPageSchemas({
	locale: 'es',
	path: '/articulos',
	name: t('seo.articles.title'),
	description: t('seo.articles.description'),
	items: articles.map((article) => ({
		name: article.data.title,
		url: `/articulos/${article.data.slug}`,
		description: article.data.excerpt,
	})),
	breadcrumbs: [
		{ name: 'Inicio', path: '/' },
		{ name: 'Articulos', path: '/articulos' },
	],
});
---

<BaseLayout
	title={t('seo.articles.title')}
	description={t('seo.articles.description')}
	locale={lang}
	esPath="/articulos"
	enPath="/en/articles"
	canonicalPath="/articulos"
	schema={schema}
>
	<ArticlesCatalog locale="es" />
</BaseLayout>
