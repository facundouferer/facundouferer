---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { withBase } from '../../utils/withBase';

export async function getStaticPaths() {
	const entries = await getCollection('articles');
	return entries.map((entry) => ({ params: { slug: entry.data.slug } }));
}

const slug = Astro.params.slug;
if (!slug) {
	throw new Error('Missing article slug');
}

const entries = await getCollection('articles');
const entry = entries.find((item) => item.data.slug === slug);
if (!entry || !entry.data.published) {
	return Astro.redirect(withBase('/articulos'));
}

const allArticles = entries
	.filter((item) => item.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const currentIndex = allArticles.findIndex((item) => item.id === entry.id);
const previous = allArticles[currentIndex + 1];
const next = allArticles[currentIndex - 1];

const { Content } = await render(entry);
const availabilityNotice =
	entry.data.lang === 'en'
		? 'Este articulo esta disponible solo en ingles / This article is available in English only'
		: undefined;
---

<ArticleLayout
	locale="es"
	article={entry.data}
	href={`/articulos/${entry.data.slug}`}
	contentDescription={entry.data.excerpt}
	ocImage={`/og/${entry.data.slug}.svg`}
	availabilityNotice={availabilityNotice}
	prev={previous
		? { title: previous.data.title, href: `/articulos/${previous.data.slug}` }
		: null}
	next={next ? { title: next.data.title, href: `/articulos/${next.data.slug}` } : null}
>
	<Content />
</ArticleLayout>
