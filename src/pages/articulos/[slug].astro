---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getArticlesForLocale, getArticleSlugsForLocale, resolveArticleEntry } from '../../utils/articles';

export async function getStaticPaths() {
	const entries = await getCollection('articles');
	return getArticleSlugsForLocale(entries, 'es', 'en').map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug;
if (!slug) {
	throw new Error('Missing article slug');
}

const entries = await getCollection('articles');
const entry = resolveArticleEntry(entries, slug, 'es', 'en');
if (!entry || !entry.data.published) {
	return Astro.redirect('/articulos');
}

const allArticles = getArticlesForLocale(entries, 'es', 'en');

const currentIndex = allArticles.findIndex((item) => item.id === entry.id);
const previous = allArticles[currentIndex + 1];
const next = allArticles[currentIndex - 1];

const { Content } = await render(entry);
---

<ArticleLayout
	locale="es"
	article={entry.data}
	href={`/articulos/${entry.data.slug}`}
	contentDescription={entry.data.excerpt}
	ocImage={`/og/${entry.data.slug}.svg`}
	prev={previous
		? { title: previous.data.title, href: `/articulos/${previous.data.slug}` }
		: null}
	next={next ? { title: next.data.title, href: `/articulos/${next.data.slug}` } : null}
>
	<Content />
</ArticleLayout>
