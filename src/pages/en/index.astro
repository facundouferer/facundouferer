---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ValueProp from '../../components/ValueProp.astro';
import FeaturedProjects from '../../components/FeaturedProjects.astro';
import FeaturedArticles from '../../components/FeaturedArticles.astro';
import Toolchain from '../../components/Toolchain.astro';
import Process from '../../components/Process.astro';
import About from '../../components/About.astro';
import Certifications from '../../components/Certifications.astro';
import Contact from '../../components/Contact.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { buildHomeSchemas } from '../../seo/schema';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const schema = buildHomeSchemas('en');
---

<BaseLayout
	title={t('seo.home.title')}
	description={t('seo.home.description')}
	locale={lang}
	esPath="/"
	enPath="/en/"
	canonicalPath="/en/"
	schema={schema}
>
	<Hero locale="en" />
	<ValueProp locale="en" />
	<FeaturedProjects locale="en" />
	<Toolchain locale="en" />
	<Process locale="en" />
	<FeaturedArticles locale="en" />
<About locale="en" />
	<Certifications locale="en" />
	<Contact locale="en" />
</BaseLayout>
