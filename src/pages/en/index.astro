---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ValueProp from '../../components/ValueProp.astro';
import FeaturedProjects from '../../components/FeaturedProjects.astro';
import FeaturedArticles from '../../components/FeaturedArticles.astro';
import Toolchain from '../../components/Toolchain.astro';
import Process from '../../components/Process.astro';
import About from '../../components/About.astro';
import Testimonials from '../../components/Testimonials.astro';
import Contact from '../../components/Contact.astro';
import { SEO } from '../../seo/meta';
import { buildHomeSchemas } from '../../seo/schema';

const schema = buildHomeSchemas('en');
---

<BaseLayout
	title={SEO.en.home.title}
	description={SEO.en.home.description}
	locale="en"
	esPath="/"
	enPath="/en/"
	canonicalPath="/en/"
	schema={schema}
>
	<Hero locale="en" />
	<ValueProp locale="en" />
	<FeaturedProjects locale="en" />
	<Toolchain locale="en" />
	<Process locale="en" />
	<FeaturedArticles locale="en" />
	<About locale="en" />
	<Testimonials locale="en" />
	<Contact locale="en" />
</BaseLayout>
