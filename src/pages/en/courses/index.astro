---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { buildCollectionPageSchemas } from '../../../seo/schema';
import { getCoursesForLocale } from '../../../utils/courses';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CourseCard from '../../../components/CourseCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const courses = getCoursesForLocale(await getCollection('courses'), 'en');
const schema = buildCollectionPageSchemas({
	locale: lang,
	path: '/en/courses',
	name: t('seo.courses.title'),
	description: t('seo.courses.description'),
	items: courses.map((course) => ({
		name: course.data.title_en,
		url: `/en/courses/${course.data.slug}`,
		description: course.data.description_en,
	})),
	breadcrumbs: [
		{ name: 'Home', path: '/en/' },
		{ name: 'Courses', path: '/en/courses' },
	],
});
---

<BaseLayout
	title={t('seo.courses.title')}
	description={t('seo.courses.description')}
	locale={lang}
	esPath="/cursos"
	enPath="/en/courses"
	canonicalPath="/en/courses"
	schema={schema}
>
	<section class="section">
		<div class="container">
			<h1 class="section-title">{t('courses.catalogTitle')}</h1>
			<p class="section-subtitle">{t('courses.catalogSubtitle')}</p>
			<div class="courses-grid">
				{courses.map((course) => (
					<CourseCard course={course.data} locale="en" />
				))}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.courses-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--space-4);
	}
</style>
