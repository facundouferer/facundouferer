---
import { getCollection, getEntry, render } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
	const entries = await getCollection('articles');
	return entries.map((entry) => ({ params: { slug: entry.data.slug } }));
}

const slug = Astro.params.slug;
if (!slug) {
	throw new Error('Missing article slug');
}

const entry = await getEntry('articles', `${slug}.md`);
if (!entry || !entry.data.published) {
	return Astro.redirect('/en/articles');
}

const allArticles = (await getCollection('articles'))
	.filter((item) => item.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const currentIndex = allArticles.findIndex((item) => item.id === entry.id);
const previous = allArticles[currentIndex + 1];
const next = allArticles[currentIndex - 1];

const { Content } = await render(entry);
const availabilityNotice =
	entry.data.lang === 'es'
		? 'This article is available in Spanish only / Este articulo esta disponible solo en espanol'
		: undefined;
---

<ArticleLayout
	locale="en"
	article={entry.data}
	href={`/en/articles/${entry.data.slug}`}
	contentDescription={entry.data.excerpt_en}
	ocImage={`/og/${entry.data.slug}.svg`}
	availabilityNotice={availabilityNotice}
	prev={previous
		? { title: previous.data.title_en, href: `/en/articles/${previous.data.slug}` }
		: null}
	next={next ? { title: next.data.title_en, href: `/en/articles/${next.data.slug}` } : null}
>
	<Content />
</ArticleLayout>
