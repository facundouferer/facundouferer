---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import {
	getArticlesForLocale,
	getArticleSlugsForLocale,
	resolveArticleEntry,
} from '../../../utils/articles';

export async function getStaticPaths() {
	const entries = await getCollection('articles');
	return getArticleSlugsForLocale(entries, 'en', 'es').map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug;
if (!slug) {
	throw new Error('Missing article slug');
}

const entries = await getCollection('articles');
const entry = resolveArticleEntry(entries, slug, 'en', 'es');
if (!entry || !entry.data.published) {
	return Astro.redirect('/en/articles');
}

const allArticles = getArticlesForLocale(entries, 'en', 'es');

const currentIndex = allArticles.findIndex((item) => item.id === entry.id);
const previous = allArticles[currentIndex + 1];
const next = allArticles[currentIndex - 1];

const { Content } = await render(entry);
---

<ArticleLayout
	locale="en"
	article={entry.data}
	href={`/en/articles/${entry.data.slug}`}
	contentDescription={entry.data.excerpt_en}
	ocImage={`/og/${entry.data.slug}.svg`}
	prev={previous
		? { title: previous.data.title_en, href: `/en/articles/${previous.data.slug}` }
		: null}
	next={next ? { title: next.data.title_en, href: `/en/articles/${next.data.slug}` } : null}
>
	<Content />
</ArticleLayout>
