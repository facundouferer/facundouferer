---
import { getCollection } from 'astro:content';
import ProjectsCatalog from '../../components/ProjectsCatalog.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { buildCollectionPageSchemas } from '../../seo/schema';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projects = (await getCollection('projects')).filter((item) => item.data.published);
const schema = buildCollectionPageSchemas({
	locale: 'en',
	path: '/en/projects',
	name: t('seo.projects.title'),
	description: t('seo.projects.description'),
	items: projects.map((project) => ({
		name: project.data.title_en,
		url: project.data.liveUrl,
		description: project.data.description_en,
	})),
	breadcrumbs: [
		{ name: 'Home', path: '/en/' },
		{ name: 'Projects', path: '/en/projects' },
	],
});
---

<BaseLayout
	title={t('seo.projects.title')}
	description={t('seo.projects.description')}
	locale={lang}
	esPath="/proyectos"
	enPath="/en/projects"
	canonicalPath="/en/projects"
	schema={schema}
>
	<ProjectsCatalog locale="en" />
</BaseLayout>
