---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SEO } from '../seo/meta';
import Hero from '../components/Hero.astro';
import ValueProp from '../components/ValueProp.astro';
import FeaturedProjects from '../components/FeaturedProjects.astro';
import FeaturedArticles from '../components/FeaturedArticles.astro';
import Toolchain from '../components/Toolchain.astro';
import Process from '../components/Process.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout
	title={SEO.es.home.title}
	description={SEO.es.home.description}
	locale="es"
	esPath="/"
	enPath="/en/"
	canonicalPath="/"
>
	<Hero locale="es" />
	<ValueProp locale="es" />
	<FeaturedProjects locale="es" />
	<Toolchain locale="es" />
	<Process locale="es" />
	<FeaturedArticles locale="es" />
	<About locale="es" />
	<Contact locale="es" />
</BaseLayout>
