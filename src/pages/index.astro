	description="Ingeniero Full Stack Senior especializado en desarrollo asistido por IA."
	locale="es"
	esPath="/"
	enPath="/en/"
	canonicalPath="/"
>
	<section class="section">
		<div class="container glass" style="padding:2rem;">
			<h1 class="section-title">Software listo para produccion a la velocidad del pensamiento.</h1>
			<p class="section-subtitle">No solo escribo codigo, orquesto inteligencia.</p>
		</div>
	</section>
	<section class="section" id="about">
		<div class="container">
			<h2 class="section-title">Sobre mi</h2>
		</div>
	</section>
	<section class="section" id="contact">
		<div class="container">
			<h2 class="section-title">Contacto</h2>
		</div>
	</section>
</BaseLayout>
