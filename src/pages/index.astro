---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ValueProp from '../components/ValueProp.astro';
import FeaturedProjects from '../components/FeaturedProjects.astro';
import FeaturedArticles from '../components/FeaturedArticles.astro';
import Toolchain from '../components/Toolchain.astro';
import Process from '../components/Process.astro';
import About from '../components/About.astro';
import Certifications from '../components/Certifications.astro';
import Contact from '../components/Contact.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { buildHomeSchemas } from '../seo/schema';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const schema = buildHomeSchemas('es');
---

<BaseLayout
	title={t('seo.home.title')}
	description={t('seo.home.description')}
	locale={lang}
	esPath="/"
	enPath="/en/"
	canonicalPath="/"
	schema={schema}
>
	<Hero locale="es" />
	<ValueProp locale="es" />
	<FeaturedProjects locale="es" />
	<Toolchain locale="es" />
	<Process locale="es" />
	<FeaturedArticles locale="es" />
	<About locale="es" />
	<Certifications locale="es" />
	<Contact locale="es" />
</BaseLayout>
