---
/**
 * Site-wide interactive particles background (particles.js).
 *
 * Renders a fixed, full-viewport particle field behind all page content.
 * - Hover repels particles, click spawns new ones
 * - `pointer-events: none` so clicks pass through to real UI
 * - Falls back to a static gradient on touch / reduced-motion / small viewports
 */
---

<div id="particles-js" aria-hidden="true"></div>

<style is:global>
	#particles-js {
		position: fixed;
		inset: 0;
		width: 100vw;
		height: 100vh;
		z-index: 0;
		pointer-events: none;
		background-color: #030014;
	}

	#particles-js canvas {
		display: block;
	}

	html {
		background: #030014 !important;
	}
	body {
		background: transparent !important;
	}

	body::before,
	body::after {
		display: none !important;
	}

	@media (prefers-reduced-motion: reduce),
	       (hover: none) and (pointer: coarse),
	       (max-width: 768px) {
		#particles-js {
			background:
				radial-gradient(ellipse at 30% 20%, rgba(117, 0, 103, 0.35), transparent 55%),
				radial-gradient(ellipse at 70% 80%, rgba(255, 57, 220, 0.18), transparent 55%),
				#030014;
		}
		#particles-js canvas {
			display: none;
		}
	}
</style>

<script
	is:inline
	src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"
></script>

<script is:inline>
	(function () {
		const mm = window.matchMedia;
		if (mm) {
			const reducedMotion = mm("(prefers-reduced-motion: reduce)").matches;
			const isTouch       = mm("(hover: none) and (pointer: coarse)").matches;
			const isSmall       = mm("(max-width: 768px)").matches;
			if (reducedMotion || isTouch || isSmall) return;
		}

		function boot() {
			if (typeof particlesJS !== "function") {
				setTimeout(boot, 60);
				return;
			}
			particlesJS("particles-js", {
				particles: {
					number: { value: 80, density: { enable: true, value_area: 800 } },
					color: { value: "#750067" },
					shape: {
						type: "circle",
						stroke: { width: 0, color: "#000000" },
						polygon: { nb_sides: 5 },
						image: { src: "img/github.svg", width: 100, height: 100 }
					},
					opacity: {
						value: 0.5,
						random: false,
						anim: { enable: false, speed: 1, opacity_min: 0.1, sync: false }
					},
					size: {
						value: 3,
						random: true,
						anim: { enable: false, speed: 40, size_min: 0.1, sync: false }
					},
					line_linked: {
						enable: true,
						distance: 150,
						color: "#ff39dc",
						opacity: 0.20517838682439088,
						width: 1
					},
					move: {
						enable: true,
						speed: 6,
						direction: "none",
						random: false,
						straight: false,
						out_mode: "out",
						bounce: false,
						attract: { enable: false, rotateX: 600, rotateY: 1200 }
					}
				},
				interactivity: {
					detect_on: "window",
					events: {
						onhover: { enable: true, mode: "repulse" },
						onclick: { enable: true, mode: "push" },
						resize: true
					},
					modes: {
						grab: { distance: 400, line_linked: { opacity: 1 } },
						bubble: { distance: 400, size: 40, duration: 2, opacity: 8, speed: 3 },
						repulse: { distance: 200, duration: 0.4 },
						push: { particles_nb: 4 },
						remove: { particles_nb: 2 }
					}
				},
				retina_detect: true
			});
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", boot);
		} else {
			boot();
		}
	})();
</script>
