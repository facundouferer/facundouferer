---

<section class="section" id="certifications">
	<div class="container">
		<p class="kicker">{t('certifications.kicker')}</p>
		<h2 class="section-title">
			{t('certifications.titleStart')}{' '}
			<span class="accent-word">{t('certifications.titleAccent')}</span>
		</h2>
		<p class="section-subtitle">{t('certifications.subtitle')}</p>
		<div class="cert-grid">
			{
				certifications.map((cert) => (
					<a
						class="cert-card card card-hover"
						href={cert.url}
						target="_blank"
						rel="noreferrer"
						aria-label={`${t('certifications.viewCredential')} ${cert.name}`}
					>
						<span class:list={['cert-badge', { 'accent-2': cert.accent2 }]}>
							<svg class="cert-badge-shield" viewBox="0 0 24 24" aria-hidden="true">
								<path d={shieldPath} />
							</svg>
							<span class="cert-badge-logo">
								{cert.logo === 'utn' ? (
									<img src={withBase('/img/certifications/utn-logo.png')} alt="" aria-hidden="true" />
								) : cert.logo ? (
									<svg viewBox="0 0 24 24" aria-hidden="true" set:html={logos[cert.logo]} />
								) : (
									<span aria-hidden="true">{cert.issuer.charAt(0)}</span>
								)}
							</span>
						</span>
						<h3 class="card-title">{cert.name}</h3>
						<p class="cert-issuer">{cert.issuer}</p>
					</a>
				))
			}
		</div>
	</div>
</section>

<style>
	.cert-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: var(--space-4);
		margin-top: var(--space-6);
	}

	.cert-card {
		text-decoration: none;
		color: inherit;
	}

	.cert-badge {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 68px;
		height: 68px;
		margin-bottom: var(--space-2);
	}

	.cert-badge-shield {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.06));
	}

	.cert-badge-shield path {
		fill: var(--color-accent-100);
		stroke: var(--color-accent-600);
		stroke-width: 1;
	}

	.cert-badge.accent-2 .cert-badge-shield path {
		fill: var(--color-accent-2-100);
		stroke: var(--color-accent-2-600);
	}

	.cert-badge-logo {
		position: relative;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		margin-top: -0.2em;
		color: var(--color-accent-700);
		font-family: var(--font-heading);
		font-weight: var(--font-heading-weight);
		font-size: 1.1rem;
	}

	.cert-badge.accent-2 .cert-badge-logo {
		color: var(--color-accent-2-700);
	}

	.cert-badge-logo svg {
		width: 100%;
		height: 100%;
		fill: currentColor;
	}

	.cert-badge-logo img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.cert-issuer {
		margin: 0;
		font-size: 13px;
		font-weight: 600;
		color: color-mix(in srgb, var(--color-text) 78%, transparent);
	}

</style>
