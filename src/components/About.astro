---
import { withBase } from '../utils/withBase';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const content = {
	es: {
		tag: 'SOBRE MI',
		title: 'Ingeniería de Software Asistida con Inteligencia Artificial.',
		p1: 'No solo escribo codigo — diseno ecosistemas que escalan sin romperse. Con mas de 10 años de experiencia, combino arquitectura robusta con ingenieria asistida por IA.',
		p2: 'Mi filosofia es el futurismo pragmatico: tecnologia de vanguardia aplicada con foco en impacto real, escalabilidad y mantenibilidad.',
	},
	en: {
		tag: 'ABOUT',
		title: 'AI-Assisted Software Engineering.',
		p1: 'I do not just write code — I architect ecosystems that scale safely. With over 10 years of experience, I combine robust architecture with AI-assisted engineering.',
		p2: 'My philosophy is pragmatic futurism: cutting-edge technology applied with real impact, scalability, and maintainability in mind.',
	},
}[locale];
---

<section class="section" id="about">
	<div class="container about-shell">
		<figure class="about-photo washed">
			<img
				src={withBase('/foto_facundo_01.png')}
				alt="Facundo Uferer"
				loading="lazy"
			/>
		</figure>
		<div class="about-content">
			<p class="kicker">{content.tag}</p>
			<h2 class="section-title">{content.title}</h2>
			<p class="about-text">{content.p1}</p>
			<p class="about-text">{content.p2}</p>
		</div>
	</div>
</section>

<style>
	.about-shell {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-8);
		align-items: center;
	}

	.about-photo {
		width: clamp(200px, 26vw, 300px);
		aspect-ratio: 1 / 1;
		margin: 0;
		border-radius: 50%;
		overflow: hidden;
		background: var(--color-surface);
	}

	.about-photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.about-content {
		display: grid;
		gap: var(--space-2);
	}

	.about-text {
		color: color-mix(in srgb, var(--color-text) 78%, transparent);
		margin: 0;
		font-size: 1rem;
		line-height: 1.7;
	}

	@media (width < 760px) {
		.about-shell {
			grid-template-columns: 1fr;
			justify-items: center;
			text-align: center;
			gap: var(--space-4);
		}

		.about-photo {
			width: min(60vw, 260px);
		}
	}
</style>
