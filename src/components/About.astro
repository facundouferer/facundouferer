---
import { withBase } from '../utils/withBase';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const content = {
	es: {
		tag: 'SOBRE MI',
		title: 'Ingeniería de Software Asistida con Inteligencia Artificial.',
		p1: 'No solo escribo codigo — diseno ecosistemas que escalan sin romperse. Con mas de 10 años de experiencia, combino arquitectura robusta con ingenieria asistida por IA.',
		p2: 'Mi filosofia es el futurismo pragmatico: tecnologia de vanguardia aplicada con foco en impacto real, escalabilidad y mantenibilidad.',
		stats: [
			{ value: '99.99%', label: 'Uptime promedio' },
		],
	},
	en: {
		tag: 'ABOUT',
		title: 'AI-Assisted Software Engineering.',
		p1: 'I do not just write code — I architect ecosystems that scale safely. With over 10 years of experience, I combine robust architecture with AI-assisted engineering.',
		p2: 'My philosophy is pragmatic futurism: cutting-edge technology applied with real impact, scalability, and maintainability in mind.',
		stats: [
			{ value: '99.99%', label: 'Average Uptime' },
		],
	},
}[locale];
---

<section class="section" id="about">
	<div class="container about-shell">
		<div class="about-image-wrapper">
			<img
				class="about-image-layer layer-base"
				src={withBase('/foto_facundo_01.png')}
				alt="Facundo Uferer"
				loading="lazy"
			/>
			<img
				class="about-image-layer layer-two"
				src={withBase('/foto_facundo_02.png')}
				alt=""
				aria-hidden="true"
				loading="lazy"
			/>
			<img
				class="about-image-layer layer-three"
				src={withBase('/foto_facundo_03.png')}
				alt=""
				aria-hidden="true"
				loading="lazy"
			/>
			<div class="glitch-scan" aria-hidden="true"></div>
			<div class="image-glow" aria-hidden="true"></div>
		</div>
		<div class="about-content">
			<p class="about-tag">{content.tag}</p>
			<h2 class="section-title">
				<span class="gradient-text">{content.title}</span>
			</h2>
			<p class="about-text">{content.p1}</p>
			<p class="about-text">{content.p2}</p>
			<div class="about-stats">
				{
					content.stats.map((stat) => (
						<div class="about-stat">
							<span class="about-stat-value">{stat.value}</span>
							<span class="about-stat-label">{stat.label}</span>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	.about-shell {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
	}

	.about-image-wrapper {
		position: relative;
		aspect-ratio: 1 / 1;
		overflow: hidden;
		border-radius: 1.2rem;
		border: 1px solid var(--color-border);
	}

	.about-image-layer {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 1;
		opacity: 0;
	}

	.layer-base {
		animation: glitch-base 6s linear infinite;
	}

	.layer-two {
		mix-blend-mode: screen;
		animation: glitch-layer-two 6s linear infinite;
	}

	.layer-three {
		mix-blend-mode: lighten;
		animation: glitch-layer-three 6s linear infinite;
	}

	.glitch-scan {
		position: absolute;
		inset: 0;
		z-index: 2;
		pointer-events: none;
		background:
			repeating-linear-gradient(
				180deg,
				transparent 0,
				transparent 22px,
				rgb(249 24 214 / 12%) 23px,
				transparent 24px
			),
			linear-gradient(100deg, transparent 20%, rgb(6 182 212 / 18%) 30%, transparent 45%);
		mix-blend-mode: screen;
		opacity: 0.35;
		animation: glitch-scan 1.6s linear infinite;
	}

	.image-glow {
		position: absolute;
		bottom: -20px;
		left: -20px;
		right: -20px;
		height: 60%;
		background: radial-gradient(ellipse at center bottom, rgb(168 85 247 / 18%), transparent 70%);
		z-index: 0;
		filter: blur(30px);
	}

	@keyframes glitch-base {
		0%,
		31% {
			opacity: 1;
			transform: translate3d(0, 0, 0);
			clip-path: inset(0 0 0 0);
		}
		33% {
			opacity: 0.7;
			transform: translate3d(-10px, 1px, 0);
			clip-path: inset(12% 0 30% 0);
		}
		35%,
		100% {
			opacity: 0;
			transform: translate3d(0, 0, 0);
			clip-path: inset(0 0 0 0);
		}
	}

	@keyframes glitch-layer-two {
		0%,
		31%,
		68%,
		100% {
			opacity: 0;
			transform: translate3d(0, 0, 0);
			clip-path: inset(0 0 0 0);
		}
		33% {
			opacity: 0.82;
			transform: translate3d(7px, 0, 0);
			clip-path: inset(4% 0 24% 0);
		}
		35%,
		64% {
			opacity: 1;
			transform: translate3d(0, 0, 0);
			clip-path: inset(0 0 0 0);
		}
		66% {
			opacity: 0.4;
			transform: translate3d(8px, -1px, 0);
			clip-path: inset(30% 0 16% 0);
		}
	}

	@keyframes glitch-layer-three {
		0%,
		64%,
		98%,
		100% {
			opacity: 0;
			transform: translate3d(0, 0, 0);
			clip-path: inset(0 0 0 0);
		}
		66% {
			opacity: 0.78;
			transform: translate3d(-8px, 0, 0);
			clip-path: inset(8% 0 20% 0);
		}
		68%,
		95% {
			opacity: 1;
			transform: translate3d(0, 0, 0);
			clip-path: inset(0 0 0 0);
		}
		97% {
			opacity: 0.42;
			transform: translate3d(6px, 1px, 0);
			clip-path: inset(24% 0 33% 0);
		}
	}

	@keyframes glitch-scan {
		from {
			transform: translate3d(0, -5%, 0);
		}
		to {
			transform: translate3d(0, 5%, 0);
		}
	}

	.about-content {
		display: grid;
		gap: 1rem;
	}

	.about-tag {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-cyan);
		margin: 0;
	}

	.about-text {
		color: var(--color-muted);
		margin: 0;
		font-size: 1rem;
		line-height: 1.7;
	}

	.about-stats {
		display: flex;
		gap: 3rem;
		margin-top: 1rem;
		padding-top: 1.2rem;
		border-top: 1px solid var(--color-border);
	}

	.about-stat {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.about-stat-value {
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 3vw, 2.6rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		background: var(--grad-primary);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.about-stat-label {
		font-size: 0.78rem;
		color: var(--color-muted);
		font-family: var(--font-mono);
		letter-spacing: 0.04em;
	}

	@media (width < 760px) {
		.about-shell {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.about-image-wrapper {
			max-width: 280px;
			aspect-ratio: 1;
		}

		.about-stats {
			gap: 2rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.about-image-layer,
		.glitch-scan {
			animation: none;
		}

		.layer-base {
			opacity: 1;
		}
	}
</style>
