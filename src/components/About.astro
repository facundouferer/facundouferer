---
import { withBase } from '../utils/withBase';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const content = {
	es: {
		tag: 'SOBRE MI',
		title: 'Ingeniería de Software Asistida con Inteligencia Artificial.',
		p1: 'No solo escribo codigo — diseno ecosistemas que escalan sin romperse. Con mas de 10 años de experiencia, combino arquitectura robusta con ingenieria asistida por IA.',
		p2: 'Mi filosofia es el futurismo pragmatico: tecnologia de vanguardia aplicada con foco en impacto real, escalabilidad y mantenibilidad.',
	},
	en: {
		tag: 'ABOUT',
		title: 'AI-Assisted Software Engineering.',
		p1: 'I do not just write code — I architect ecosystems that scale safely. With over 10 years of experience, I combine robust architecture with AI-assisted engineering.',
		p2: 'My philosophy is pragmatic futurism: cutting-edge technology applied with real impact, scalability, and maintainability in mind.',
	},
}[locale];
---

<section class="section" id="about">
	<div class="container about-shell">
		<div class="about-image-wrapper">
			<div class="orbital-ring orbital-ring-outer" aria-hidden="true"></div>
			<div class="orbital-ring orbital-ring-inner" aria-hidden="true"></div>
			<img
				class="about-image-layer layer-base"
				src={withBase('/foto_facundo_01.png')}
				alt="Facundo Uferer"
				loading="lazy"
			/>
			<img
				class="about-image-layer layer-two glitch-layer"
				src={withBase('/foto_facundo_02.png')}
				alt=""
				aria-hidden="true"
				loading="lazy"
			/>
			<img
				class="about-image-layer layer-three glitch-layer"
				src={withBase('/foto_facundo_03.png')}
				alt=""
				aria-hidden="true"
				loading="lazy"
			/>
			<div class="orbital-flare" aria-hidden="true"></div>
			<div class="image-glow" aria-hidden="true"></div>
		</div>
		<div class="about-content">
			<p class="about-tag">{content.tag}</p>
			<h2 class="section-title">
				<span class="gradient-text">{content.title}</span>
			</h2>
			<p class="about-text">{content.p1}</p>
			<p class="about-text">{content.p2}</p>
		</div>
	</div>
</section>

<style>
	.about-shell {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
	}

	.about-image-wrapper {
		position: relative;
		width: min(100%, clamp(220px, 32vw, 360px));
		max-width: clamp(220px, 32vw, 360px);
		aspect-ratio: 1 / 1;
		overflow: hidden;
		border-radius: 50%;
		border: 1px solid rgb(94 234 212 / 22%);
		justify-self: center;
		isolation: isolate;
		box-shadow:
			0 0 0 1px rgb(167 139 250 / 16%),
			0 0 24px rgb(34 211 238 / 22%),
			0 0 52px rgb(217 70 239 / 24%);
		background:
			radial-gradient(circle at 50% 50%, rgb(8 3 24 / 10%) 55%, rgb(8 3 24 / 88%) 100%);
	}

	.about-image-layer {
		position: absolute;
		inset: 5.5%;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 1;
		opacity: 0;
		border-radius: 50%;
		transform-origin: 50% 50%;
		filter:
			saturate(1.05)
			contrast(1.05)
			drop-shadow(0 0 14px rgb(56 189 248 / 20%))
			drop-shadow(0 0 22px rgb(217 70 239 / 18%));
	}

	.layer-base {
		animation: orbital-base 12s linear infinite;
	}

	.layer-two {
		mix-blend-mode: screen;
		animation: orbital-layer-two 12s linear infinite;
	}

	.layer-three {
		mix-blend-mode: lighten;
		animation: orbital-layer-three 12s linear infinite;
	}

	.orbital-ring {
		position: absolute;
		inset: 0;
		z-index: 2;
		pointer-events: none;
		border-radius: 50%;
	}

	.orbital-ring-outer {
		inset: 2%;
		border: 1px solid rgb(34 211 238 / 20%);
		background:
			conic-gradient(
				from 0deg,
				transparent 0deg,
				rgb(34 211 238 / 0.75) 52deg,
				transparent 108deg,
				transparent 220deg,
				rgb(217 70 239 / 0.72) 280deg,
				transparent 332deg
			);
		filter: blur(1px) drop-shadow(0 0 10px rgb(34 211 238 / 38%)) drop-shadow(0 0 18px rgb(217 70 239 / 30%));
		opacity: 0.9;
		animation: spin-ring 8s linear infinite;
	}

	.orbital-ring-inner {
		inset: 7%;
		border: 1px solid rgb(255 255 255 / 10%);
		box-shadow:
			inset 0 0 22px rgb(217 70 239 / 16%),
			inset 0 0 32px rgb(56 189 248 / 12%);
		opacity: 0.9;
	}

	.orbital-flare {
		position: absolute;
		inset: -6%;
		z-index: 2;
		pointer-events: none;
		border-radius: 50%;
		background:
			conic-gradient(
				from 90deg,
				transparent 0deg,
				rgb(255 255 255 / 0.05) 28deg,
				rgb(34 211 238 / 0.42) 52deg,
				transparent 96deg,
				transparent 220deg,
				rgb(217 70 239 / 0.4) 280deg,
				transparent 332deg
			);
		filter: blur(10px);
		mix-blend-mode: screen;
		animation: flare-pulse 4.2s ease-in-out infinite;
	}

	.image-glow {
		position: absolute;
		inset: 10%;
		background:
			radial-gradient(circle at 35% 30%, rgb(34 211 238 / 26%), transparent 34%),
			radial-gradient(circle at 68% 72%, rgb(217 70 239 / 28%), transparent 36%),
			radial-gradient(circle at 50% 50%, rgb(192 132 252 / 14%), transparent 60%);
		z-index: 0;
		filter: blur(30px);
		animation: glow-breathe 3.8s ease-in-out infinite;
	}

	@keyframes orbital-base {
		0%,
		24% {
			opacity: 1;
			transform: rotate(0deg) scale(1);
		}
		32% {
			opacity: 0.22;
			transform: rotate(110deg) scale(0.96);
		}
		38%,
		100% {
			opacity: 0;
			transform: rotate(180deg) scale(0.94);
		}
	}

	@keyframes orbital-layer-two {
		0%,
		24%,
		72%,
		100% {
			opacity: 0;
			transform: rotate(-120deg) scale(1.02);
		}
		30% {
			opacity: 0.16;
			transform: rotate(-40deg) scale(1.03);
		}
		38%,
		62% {
			opacity: 1;
			transform: rotate(0deg) scale(1);
		}
		70% {
			opacity: 0.18;
			transform: rotate(96deg) scale(0.97);
		}
	}

	@keyframes orbital-layer-three {
		0%,
		58%,
		96%,
		100% {
			opacity: 0;
			transform: rotate(160deg) scale(1.05);
		}
		64% {
			opacity: 0.16;
			transform: rotate(60deg) scale(1.02);
		}
		72%,
		90% {
			opacity: 1;
			transform: rotate(0deg) scale(1);
		}
	}

	@keyframes spin-ring {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	@keyframes flare-pulse {
		0%,
		100% {
			opacity: 0.55;
			transform: scale(0.98) rotate(0deg);
		}
		50% {
			opacity: 0.95;
			transform: scale(1.04) rotate(18deg);
		}
	}

	@keyframes glow-breathe {
		0%,
		100% {
			opacity: 0.7;
			transform: scale(0.98);
		}
		50% {
			opacity: 1;
			transform: scale(1.04);
		}
	}

	.about-content {
		display: grid;
		gap: 1rem;
	}

	.about-tag {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-cyan);
		margin: 0;
	}

	.about-text {
		color: var(--color-muted);
		margin: 0;
		font-size: 1rem;
		line-height: 1.7;
	}

	@media (width < 760px) {
		.about-shell {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.about-image-wrapper {
			max-width: min(78vw, 290px);
			aspect-ratio: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.about-image-layer,
		.orbital-ring-outer,
		.orbital-flare,
		.image-glow {
			animation: none;
		}

		.layer-base {
			opacity: 1;
			transform: none;
		}

		.layer-two,
		.layer-three {
			opacity: 0;
		}
	}
</style>
