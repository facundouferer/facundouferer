---
import { useTranslations } from '../i18n/utils';
import { withBase } from '../utils/withBase';

type Project = {
	title: string;
	title_en: string;
	description: string;
	description_en: string;
	challenge: string;
	challenge_en: string;
	aiRole: string;
	aiRole_en: string;
	tags: string[];
	image: string;
	liveUrl: string;
	archived?: boolean;
};

type Props = {
	project: Project;
	locale: 'es' | 'en';
};

const { project, locale } = Astro.props;
const t = useTranslations(locale);
const title = locale === 'es' ? project.title : project.title_en;
const description = locale === 'es' ? project.description : project.description_en;
const challenge = locale === 'es' ? project.challenge : project.challenge_en;
const imageSrc = project.image.startsWith('/') ? withBase(project.image) : project.image;
---

<article class="project-card card card-hover">
	<a href={project.liveUrl} target="_blank" rel="noreferrer" class="card-link-wrapper">
		<figure class="card-image washed">
			<img src={imageSrc} alt={title} loading="lazy" />
		</figure>
		<div class="project-content">
			<ul class="tags">
				{project.tags.slice(0, 4).map((tag) => <li class="tag tag-accent">{tag}</li>)}
			</ul>
			<h3 class="card-title">{title}</h3>
			{project.archived && <p class="archive-tag">[archived]</p>}
			<p class="card-body">{description}</p>
			<p class="challenge"><strong>{t('projectCard.challengeLabel')}</strong> {challenge}</p>
		</div>
	</a>
</article>

<style>
	.project-card {
		overflow: hidden;
		padding: 0;
	}

	.card-link-wrapper {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.card-image {
		overflow: hidden;
		margin: 0;
	}

	.card-image img {
		width: 100%;
		height: 220px;
		object-fit: cover;
		display: block;
		transition: transform 400ms ease;
	}

	.project-card:hover .card-image img {
		transform: scale(1.04);
	}

	.project-content {
		padding: var(--space-4);
		display: grid;
		gap: var(--space-2);
	}

	.tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin: 0;
		padding: 0;
	}

	.card-body {
		font-size: 0.9rem;
	}

	.challenge {
		margin: 0;
		color: color-mix(in srgb, var(--color-text) 78%, transparent);
		font-size: 0.85rem;
	}

	.archive-tag {
		margin: 0;
		font-size: 0.72rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-accent-700);
	}
</style>
