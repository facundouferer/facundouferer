---
import LanguageSwitch from './LanguageSwitch.astro';
import { NAVIGATION } from '../config/site';

type Props = {
	locale: 'es' | 'en';
	esPath?: string;
	enPath?: string;
};

const { locale, esPath, enPath } = Astro.props;
const navItems = NAVIGATION[locale];
const hireHref = locale === 'es' ? '/#contact' : '/en/#contact';
const hireLabel = locale === 'es' ? 'Contratame' : 'Hire Me';
---

<header class="site-header">
	<div class="header-inner container">
		<a href={locale === 'es' ? '/' : '/en/'} class="brand">
			<span class="brand-accent">FACUNDO</span><span class="brand-dim">UFERER</span>
		</a>
		<nav aria-label="Primary">
			<ul>
				{
					navItems.map((item) => (
						<li>
							<a href={item.href}>{item.label}</a>
						</li>
					))
				}
			</ul>
		</nav>
		<div class="header-actions">
			<LanguageSwitch locale={locale} esPath={esPath} enPath={enPath} />
			<a class="hire-cta" href={hireHref}>{hireLabel}</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		backdrop-filter: blur(16px);
		background: rgb(3 0 20 / 82%);
		border-bottom: 1px solid var(--color-border);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 4.2rem;
	}

	.brand {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 1rem;
		letter-spacing: 0.06em;
		text-decoration: none;
	}

	.brand-accent {
		color: var(--color-cyan);
	}

	.brand-dim {
		color: var(--color-muted);
	}

	nav ul {
		display: none;
		list-style: none;
		padding: 0;
		margin: 0;
		gap: 1.5rem;
	}

	nav a {
		font-size: 0.85rem;
		text-decoration: none;
		color: var(--color-muted);
		transition: color 200ms ease;
		letter-spacing: 0.02em;
	}

	nav a:hover {
		color: var(--color-text);
	}

	.header-actions {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
	}

	.hire-cta {
		padding: 0.45rem 1rem;
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-weight: 700;
		background: var(--grad-accent);
		color: #fff;
		transition: transform 180ms ease, box-shadow 180ms ease;
	}

	.hire-cta:hover {
		transform: translateY(-1px);
		box-shadow: 0 4px 20px rgb(168 85 247 / 30%);
	}

	@media (width >= 960px) {
		nav ul {
			display: inline-flex;
		}
	}
</style>
