---
import LanguageSwitch from './LanguageSwitch.astro';
import { NAVIGATION } from '../config/site';

type Props = {
	locale: 'es' | 'en';
	esPath?: string;
	enPath?: string;
};

const { locale, esPath, enPath } = Astro.props;
const navItems = NAVIGATION[locale];
const hireHref = locale === 'es' ? '/#contact' : '/en/#contact';
const hireLabel = locale === 'es' ? 'Contratame' : 'Hire Me';
---

<header class="site-header">
	<div class="header-inner container">
		<a href={locale === 'es' ? '/' : '/en/'} class="brand">Facundo Uferer</a>
		<nav aria-label="Primary">
			<ul>
				{
					navItems.map((item) => (
						<li>
							<a href={item.href}>{item.label}</a>
						</li>
					))
				}
			</ul>
		</nav>
		<div class="header-actions">
			<LanguageSwitch locale={locale} esPath={esPath} enPath={enPath} />
			<a class="hire-cta" href={hireHref}>{hireLabel}</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		backdrop-filter: blur(10px);
		background: rgb(5 5 16 / 78%);
		border-bottom: 1px solid var(--color-border);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 4.5rem;
	}

	.brand {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 1.1rem;
		text-decoration: none;
		color: var(--color-text);
	}

	nav ul {
		display: none;
		list-style: none;
		padding: 0;
		margin: 0;
		gap: 1.2rem;
	}

	nav a {
		font-size: 0.9rem;
		text-decoration: none;
		color: var(--color-muted);
	}

	nav a:hover {
		color: var(--color-text);
	}

	.header-actions {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
	}

	.hire-cta {
		padding: 0.45rem 0.9rem;
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-weight: 700;
		background: linear-gradient(90deg, var(--color-accent), var(--color-cyan));
		color: var(--color-text);
	}

	@media (width >= 960px) {
		nav ul {
			display: inline-flex;
		}
	}
</style>
