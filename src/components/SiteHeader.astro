---
import LanguageSwitch from "./LanguageSwitch.astro";
import { NAVIGATION } from "../config/site";
import { withBase } from "../utils/withBase";

type Props = {
	locale: "es" | "en";
	esPath?: string;
	enPath?: string;
};

const { locale, esPath, enPath } = Astro.props;
const navItems = NAVIGATION[locale];
const hireHref = locale === "es" ? "/#contact" : "/en/#contact";
const hireLabel = locale === "es" ? "Contratame" : "Hire Me";
const homeHref = locale === "es" ? "/" : "/en/";
---

<header class="site-header">
	<div class="nav container">
		<a href={withBase(homeHref)} class="nav-brand">
			<img class="brand-logo" src={withBase("/logos.svg")} alt="" aria-hidden="true" />
			Facundo Uferer
		</a>
		<nav aria-label="Primary" class="nav-links">
			<ul>
				{
					navItems.map((item) => (
						<li>
							<a href={withBase(item.href)}>{item.label}</a>
						</li>
					))
				}
			</ul>
		</nav>
		<div class="header-actions">
			<LanguageSwitch locale={locale} esPath={esPath} enPath={enPath} />
			<a class="btn btn-primary" href={withBase(hireHref)}>{hireLabel}</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		background: var(--color-bg);
		box-shadow: var(--shadow-sm);
	}

	.nav {
		justify-content: space-between;
		min-height: 4.2rem;
	}

	.brand-logo {
		height: auto;
		max-height: 26px;
		width: auto;
	}

	.nav-links ul {
		display: none;
		list-style: none;
		padding: 0;
		margin: 0;
		gap: var(--space-4);
	}

	.header-actions {
		display: inline-flex;
		align-items: center;
		gap: var(--space-3);
	}

	@media (width >= 960px) {
		.nav-links ul {
			display: inline-flex;
		}
	}
</style>
