---
import { getCollection } from 'astro:content';
import ArticleCard from './ArticleCard.astro';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const articles = (await getCollection('articles'))
	.filter((item) => item.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

const title = locale === 'es' ? 'Articulos Tecnicos' : 'Technical Articles';
const subtitle =
	locale === 'es'
		? 'Investigacion, analisis y pensamiento aplicado en ingenieria de software e IA.'
		: 'Research, analysis, and applied thinking on software engineering and AI.';
const href = locale === 'es' ? '/articulos' : '/en/articles';
const cta = locale === 'es' ? 'Ver todos los articulos' : 'Read all articles';
---

<section class="section">
	<div class="container">
		<h2 class="section-title">{title}</h2>
		<p class="section-subtitle">{subtitle}</p>
		<div class="articles-grid">
			{articles.map((item) => <ArticleCard article={item.data} locale={locale} />)}
		</div>
		<p class="more"><a href={href}>{cta} →</a></p>
	</div>
</section>

<style>
	.articles-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}

	.more {
		margin-top: 1rem;
	}

	.more a {
		color: var(--color-cyan);
		text-decoration: none;
		font-weight: 700;
	}
</style>
