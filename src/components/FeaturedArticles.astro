---
import { getCollection } from 'astro:content';
import ArticleCard from './ArticleCard.astro';
import { withBase } from '../utils/withBase';
import { getArticlePreviewImage, getArticlesForLocale } from '../utils/articles';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const articles = getArticlesForLocale(await getCollection('articles'), locale, locale === 'es' ? 'en' : 'es').slice(0, 3);
const articleCards = articles.map((item) => ({
	...item.data,
	image: getArticlePreviewImage(item),
}));

const title = locale === 'es' ? 'Articulos Tecnicos' : 'Technical Articles';
const subtitle =
	locale === 'es'
		? 'Investigacion, analisis y pensamiento aplicado en ingenieria de software e IA.'
		: 'Research, analysis, and applied thinking on software engineering and AI.';
const href = locale === 'es' ? '/articulos' : '/en/articles';
const cta = locale === 'es' ? 'Ver todos los articulos' : 'Read all articles';
---

<section class="section">
	<div class="container">
		<p class="section-tag">{locale === 'es' ? 'ESCRITURA' : 'WRITING'}</p>
		<h2 class="section-title">
			{title.split(' ').slice(0, -1).join(' ')}{' '}
			<span class="gradient-text">{title.split(' ').at(-1)}</span>
		</h2>
		<p class="section-subtitle">{subtitle}</p>
		<div class="articles-grid">
			{articleCards.map((item) => <ArticleCard article={item} locale={locale} />)}
		</div>
		<p class="more"><a href={withBase(href)}>{cta} →</a></p>
	</div>
</section>

<style>
	.section-tag {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-cyan);
		margin: 0 0 0.6rem;
	}

	.articles-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 1.2rem;
		margin-top: 1.8rem;
	}

	.more {
		margin-top: 1.5rem;
	}

	.more a {
		color: var(--color-cyan);
		text-decoration: none;
		font-weight: 700;
		font-size: 0.9rem;
		transition: color 200ms ease;
	}

	.more a:hover {
		color: var(--color-accent);
	}
</style>
