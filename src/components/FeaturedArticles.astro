---
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';
import ArticleCard from './ArticleCard.astro';
import { withBase } from '../utils/withBase';
import { getArticlePreviewImage, getArticlesForLocale } from '../utils/articles';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;
const t = useTranslations(locale);

const articles = getArticlesForLocale(await getCollection('articles'), locale, locale === 'es' ? 'en' : 'es').slice(0, 3);
const articleCards = articles.map((item) => ({
	...item.data,
	image: getArticlePreviewImage(item),
}));

const title = t('featured.articles.title');
const subtitle = t('featured.articles.subtitle');
const href = locale === 'es' ? '/articulos' : '/en/articles';
const cta = t('featured.articles.cta');
---

<section class="section">
	<div class="container">
		<p class="kicker">{t('featured.articles.kicker')}</p>
		<h2 class="section-title">
			{title.split(' ').slice(0, -1).join(' ')}{' '}
			<span class="accent-word">{title.split(' ').at(-1)}</span>
		</h2>
		<p class="section-subtitle">{subtitle}</p>
		<div class="articles-grid">
			{articleCards.map((item) => <ArticleCard article={item} locale={locale} />)}
		</div>
		<p class="more"><a class="btn btn-ghost" href={withBase(href)}>{cta} →</a></p>
	</div>
</section>

<style>
	.articles-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: var(--space-4);
		margin-top: var(--space-6);
	}

	.more {
		margin-top: var(--space-4);
	}
</style>
