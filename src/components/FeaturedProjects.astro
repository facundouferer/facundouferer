---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import { withBase } from '../utils/withBase';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const projects = (await getCollection('projects'))
	.filter((item) => item.data.published && item.data.featured)
	.slice(0, 2);

const title = locale === 'es' ? 'Proyectos Destacados' : 'Selected Case Studies';
const subtitle =
	locale === 'es'
		? 'Soluciones reales para desafios de infraestructura y estrategia digital.'
		: 'Real solutions for complex infrastructure and digital strategy challenges.';
const ctaHref = locale === 'es' ? '/proyectos' : '/en/projects';
const ctaLabel = locale === 'es' ? 'Ver todos los proyectos' : 'View all projects';
---

<section class="section">
	<div class="container">
		<p class="kicker">{locale === 'es' ? 'PORTAFOLIO' : 'PORTFOLIO'}</p>
		<h2 class="section-title">
			{title.split(' ').slice(0, -1).join(' ')}{' '}
			<span class="accent-word">{title.split(' ').at(-1)}</span>
		</h2>
		<p class="section-subtitle">{subtitle}</p>
		<div class="grid">
			{projects.map((project) => <ProjectCard project={project.data} locale={locale} />)}
		</div>
		<p class="more"><a class="btn btn-ghost" href={withBase(ctaHref)}>{ctaLabel} →</a></p>
	</div>
</section>

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: var(--space-4);
		margin-top: var(--space-6);
	}

	.more {
		margin-top: var(--space-4);
	}
</style>
