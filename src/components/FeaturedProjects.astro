---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const projects = (await getCollection('projects'))
	.filter((item) => item.data.published && item.data.featured)
	.slice(0, 2);

const title = locale === 'es' ? 'Proyectos destacados' : 'Selected Projects';
const subtitle =
	locale === 'es'
		? 'Una muestra de la ingenieria asistida por IA en el mundo real.'
		: 'A taste of AI-assisted engineering in the real world.';
const ctaHref = locale === 'es' ? '/proyectos' : '/en/projects';
const ctaLabel = locale === 'es' ? 'Ver todos los proyectos' : 'View all projects';
---

<section class="section">
	<div class="container">
		<h2 class="section-title">{title}</h2>
		<p class="section-subtitle">{subtitle}</p>
		<div class="grid">
			{projects.map((project) => <ProjectCard project={project.data} locale={locale} />)}
		</div>
		<p class="more"><a href={ctaHref}>{ctaLabel} →</a></p>
	</div>
</section>

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}

	.more {
		margin-top: 1rem;
	}

	.more a {
		color: var(--color-cyan);
		text-decoration: none;
		font-weight: 700;
	}
</style>
