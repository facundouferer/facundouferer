---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import { withBase } from '../utils/withBase';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const projects = (await getCollection('projects'))
	.filter((item) => item.data.published && item.data.featured)
	.slice(0, 2);

const title = locale === 'es' ? 'Proyectos Destacados' : 'Selected Case Studies';
const subtitle =
	locale === 'es'
		? 'Soluciones reales para desafios de infraestructura y estrategia digital.'
		: 'Real solutions for complex infrastructure and digital strategy challenges.';
const ctaHref = locale === 'es' ? '/proyectos' : '/en/projects';
const ctaLabel = locale === 'es' ? 'Ver todos los proyectos' : 'View all projects';
---

<section class="section">
	<div class="container">
		<p class="section-tag">{locale === 'es' ? 'PORTAFOLIO' : 'PORTFOLIO'}</p>
		<h2 class="section-title">
			{title.split(' ').slice(0, -1).join(' ')}{' '}
			<span class="gradient-text">{title.split(' ').at(-1)}</span>
		</h2>
		<p class="section-subtitle">{subtitle}</p>
		<div class="grid">
			{projects.map((project) => <ProjectCard project={project.data} locale={locale} />)}
		</div>
		<p class="more"><a href={withBase(ctaHref)}>{ctaLabel} →</a></p>
	</div>
</section>

<style>
	.section-tag {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-cyan);
		margin: 0 0 0.6rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 1.4rem;
		margin-top: 1.8rem;
	}

	.more {
		margin-top: 1.5rem;
	}

	.more a {
		color: var(--color-cyan);
		text-decoration: none;
		font-weight: 700;
		font-size: 0.9rem;
		transition: color 200ms ease;
	}

	.more a:hover {
		color: var(--color-accent);
	}
</style>
