---
import { withBase } from '../utils/withBase';

type Lesson = {
	slug: string;
	title: string;
	description?: string;
	order: number;
};

type Props = {
	lessons: Lesson[];
	courseSlug: string;
	locale: 'es' | 'en';
	currentSlug?: string;
};

const { lessons, courseSlug, locale, currentSlug } = Astro.props;
---

<ol class="lessons-list">
	{lessons.map((lesson) => {
		const href = locale === 'es'
			? `/cursos/${courseSlug}/${lesson.slug}`
			: `/en/courses/${courseSlug}/${lesson.slug}`;
		const isActive = currentSlug === lesson.slug;
		return (
			<li class="lesson-item">
				<a
					href={withBase(href)}
					class:list={{ 'lesson-link': true, 'lesson-link--active': isActive }}
					aria-current={isActive ? 'page' : undefined}
				>
					<span class="lesson-order">{lesson.order}</span>
					<span class="lesson-info">
						<span class="lesson-title">{lesson.title}</span>
						{lesson.description && <span class="lesson-desc">{lesson.description}</span>}
					</span>
				</a>
			</li>
		);
	})}
</ol>

<style>
	.lessons-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: var(--space-1);
	}

	.lesson-item {
		margin: 0;
	}

	.lesson-link {
		display: flex;
		align-items: flex-start;
		gap: var(--space-3);
		padding: var(--space-2) var(--space-3);
		border-radius: 8px;
		text-decoration: none;
		color: var(--color-text);
		transition: background 200ms ease;
		font-size: 0.9rem;
	}

	.lesson-link:hover {
		background: color-mix(in srgb, var(--color-accent-700) 8%, transparent);
	}

	.lesson-link--active {
		background: color-mix(in srgb, var(--color-accent-700) 12%, transparent);
		border-left: 3px solid var(--color-accent-700);
	}

	.lesson-order {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.7rem;
		height: 1.7rem;
		border-radius: 50%;
		background: var(--color-accent-700);
		color: #fff;
		font-size: 0.75rem;
		font-weight: 600;
		flex-shrink: 0;
	}

	.lesson-link--active .lesson-order {
		background: var(--color-accent);
	}

	.lesson-info {
		display: grid;
		gap: 0.1rem;
	}

	.lesson-title {
		font-weight: 600;
		font-size: 0.88rem;
	}

	.lesson-desc {
		font-size: 0.78rem;
		color: color-mix(in srgb, var(--color-text) 60%, transparent);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 220px;
	}
</style>
