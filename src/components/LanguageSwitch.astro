---
import { withBase } from '../utils/withBase';

type Props = {
	locale: 'es' | 'en';
	esPath?: string;
	enPath?: string;
};

const { locale, esPath = '/', enPath = '/en/' } = Astro.props;
const isSpanish = locale === 'es';
---

<div class="language-switch" aria-label="Language selector">
	<a href={withBase(esPath)} class:list={{ active: isSpanish }} aria-label="Espanol (Argentina)">🇦🇷</a>
	<span aria-hidden="true">|</span>
	<a href={withBase(enPath)} class:list={{ active: !isSpanish }} aria-label="English (United States)">🇺🇸</a>
</div>

<style>
	.language-switch {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.85rem;
	}

	.language-switch a {
		text-decoration: none;
		opacity: 0.55;
		filter: grayscale(0.4);
		transition: opacity 180ms ease, filter 180ms ease;
	}

	.language-switch a.active,
	.language-switch a:hover {
		opacity: 1;
		filter: none;
	}

	.language-switch span {
		color: var(--color-divider);
	}
</style>
