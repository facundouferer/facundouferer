---
type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const content = {
	es: {
		title: 'Por que la Ingenieria Asistida por IA lo cambia todo',
		intro:
			'Los equipos tradicionales tardan meses. Yo tardo dias. La IA acelera la ejecucion, pero las decisiones arquitectonicas siguen siendo humanas.',
		cards: [
			{ icon: 'zap', title: 'Velocidad', body: 'Del concepto a produccion en tiempo record. Lo que otros logran en meses, lo entrego en dias.' },
			{ icon: 'shield', title: 'Calidad', body: 'Revisiones multi-agente para codigo limpio, testeado y robusto en cada delivery.' },
			{ icon: 'layers', title: 'Ownership Full Stack', body: 'Arquitectura, frontend, backend, DevOps y UX — todo bajo un mismo criterio de ingeniero.' },
		],
	},
	en: {
		title: 'Why AI-Assisted Engineering Changes Everything',
		intro:
			'Traditional teams take months. I take days. AI accelerates execution while architecture decisions remain human.',
		cards: [
			{ icon: 'zap', title: 'Speed', body: 'From concept to production in record time. What others achieve in months, I deliver in days.' },
			{ icon: 'shield', title: 'Quality', body: 'Multi-agent review cycles for cleaner, tested, and safer code in every delivery.' },
			{ icon: 'layers', title: 'Full Stack Ownership', body: 'Architecture, frontend, backend, DevOps, and UX — all under one engineering vision.' },
		],
	},
}[locale];

const icons: Record<string, string> = {
	zap: '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>',
	shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>',
	layers:
		'<path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z"/><path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12"/><path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17"/>',
};
---

<section class="section">
	<div class="container">
		<h2 class="section-title">
			{content.title.split(' ').slice(0, -1).join(' ')}{' '}
			<span class="accent-word">{content.title.split(' ').at(-1)}</span>
		</h2>
		<p class="section-subtitle">{content.intro}</p>
		<div class="cards">
			{
				content.cards.map((card) => (
					<article class="vp-card card card-hover">
						<span class="card-icon" set:html={icons[card.icon]} />
						<h3 class="card-title">{card.title}</h3>
						<p class="card-body">{card.body}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: var(--space-4);
		margin-top: var(--space-6);
	}

	.vp-card svg {
		width: 20px;
		height: 20px;
		fill: none;
		stroke: currentColor;
		stroke-width: 2.75;
		stroke-linecap: round;
		stroke-linejoin: round;
	}
</style>
