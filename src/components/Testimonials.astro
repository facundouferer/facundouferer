---
type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const title = locale === 'es' ? 'Referencias' : 'Testimonials';
const items =
	locale === 'es'
		? [
			{
				quote: 'Es el mejor programador del mundo',
				author: '(Mi mamá)',
			},
			{
				quote: 'Siempre nos asiste en todo lo que necesitamos',
				author: '(Papá)',
			},
			{
				quote: 'Pocos programadores son tan buenos como él',
				author: '(Mi Abuela)',
			},
		]
		: [
			{
				quote: 'He is the best programmer in the world',
				author: '(My Mom)',
			},
			{
				quote: 'He always helps us with everything we need',
				author: '(My Dad)',
			},
			{
				quote: 'Very few programmers are as good as he is',
				author: '(My Grandma)',
			},
		];
---

<section class="section">
	<div class="container">
		<h2 class="section-title">{title}</h2>
		<div class="grid">
			{
				items.map((item) => (
					<blockquote class="testimonial-card card">
						<div class="quote-mark" aria-hidden="true">“</div>
						<p>{item.quote}</p>
						<cite>{item.author}</cite>
					</blockquote>
				))
			}
		</div>
	</div>
</section>

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: var(--space-4);
		margin-top: var(--space-6);
	}

	.testimonial-card {
		margin: 0;
	}

	.quote-mark {
		font-family: var(--font-heading);
		font-weight: var(--font-heading-weight);
		font-size: 3rem;
		line-height: 1;
		color: var(--color-accent-700);
		margin-bottom: -0.6rem;
	}

	.testimonial-card p {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--color-text);
	}

	.testimonial-card cite {
		display: block;
		margin-top: var(--space-2);
		font-style: normal;
		font-size: 0.8rem;
		color: color-mix(in srgb, var(--color-text) 55%, transparent);
	}
</style>
