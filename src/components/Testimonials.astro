---
type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const title = locale === 'es' ? 'Referencias' : 'Testimonials';
const items =
	locale === 'es'
		? [
			{
				quote: 'Facundo convierte ideas complejas en productos reales con una velocidad impresionante.',
				author: 'Directora de Producto, EdTech',
			},
			{
				quote: 'Excelente criterio tecnico y gran capacidad para liderar decisiones de arquitectura.',
				author: 'CTO, Startup SaaS',
			},
			{
				quote: 'Una combinacion rara: rapidez, calidad y comunicacion clara con equipos no tecnicos.',
				author: 'Coordinacion de Innovacion Publica',
			},
		]
		: [
			{
				quote: 'Facundo turns complex ideas into production products at remarkable speed.',
				author: 'Product Director, EdTech',
			},
			{
				quote: 'Strong architecture judgment and excellent technical leadership.',
				author: 'CTO, SaaS Startup',
			},
			{
				quote: 'Rare combination of speed, quality, and communication with non-technical teams.',
				author: 'Public Innovation Coordination',
			},
		];
---

<section class="section">
	<div class="container">
		<h2 class="section-title">{title}</h2>
		<div class="grid">
			{
				items.map((item) => (
					<blockquote class="glass card">
						<p>“{item.quote}”</p>
						<cite>{item.author}</cite>
					</blockquote>
				))
			}
		</div>
	</div>
</section>

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.card {
		margin: 0;
		padding: 1rem;
	}

	.card p {
		margin: 0;
	}

	.card cite {
		display: block;
		margin-top: 0.8rem;
		font-style: normal;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-muted);
	}
</style>
