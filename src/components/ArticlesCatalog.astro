---
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';
import ArticleCard from './ArticleCard.astro';
import { getArticlePreviewImage, getArticlesForLocale } from '../utils/articles';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;
const t = useTranslations(locale);

const articles = getArticlesForLocale(await getCollection('articles'), locale, locale === 'es' ? 'en' : 'es');
const articleCards = articles.map((item) => ({
	...item.data,
	image: getArticlePreviewImage(item),
}));

const categories = ['All', ...new Set(articleCards.map((item) => item.category))];
const tags = ['All', ...new Set(articleCards.flatMap((item) => item.tags))];

const title = t('catalog.articles.title');
const subtitle = t('catalog.articles.subtitle');
---

<section class="section">
	<div class="container">
		<h1 class="section-title">{title}</h1>
		<p class="section-subtitle">{subtitle}</p>
		<div class="filters">
			<label>
				Category
				<select id="category-filter" class="input">
					{categories.map((category) => <option value={category}>{category}</option>)}
				</select>
			</label>
			<label>
				Tag
				<select id="tag-filter" class="input">
					{tags.map((tag) => <option value={tag}>{tag}</option>)}
				</select>
			</label>
		</div>
		<div class="articles-grid" id="articles-grid">
			{articleCards.map((item) => <ArticleCard article={item} locale={locale} />)}
		</div>
		<div class="pager" id="articles-pager">
			<button type="button" class="btn btn-secondary" id="prev-page">← Prev</button>
			<span id="page-indicator">1</span>
			<button type="button" class="btn btn-secondary" id="next-page">Next →</button>
		</div>
	</div>
</section>

<script>
	const categoryFilter = document.querySelector('#category-filter');
	const tagFilter = document.querySelector('#tag-filter');
	const cards = Array.from(document.querySelectorAll('.article-card')) as HTMLElement[];
	const prevButton = document.querySelector('#prev-page');
	const nextButton = document.querySelector('#next-page');
	const pageIndicator = document.querySelector('#page-indicator');
	let currentPage = 1;
	const pageSize = 9;

	const applyPagination = () => {
		const visibleCards = cards.filter((card) => !card.hasAttribute('hidden'));
		const totalPages = Math.max(1, Math.ceil(visibleCards.length / pageSize));
		if (currentPage > totalPages) currentPage = totalPages;

		for (const [index, card] of visibleCards.entries()) {
			const onPage = index >= (currentPage - 1) * pageSize && index < currentPage * pageSize;
			card.toggleAttribute('data-page-hidden', !onPage);
			card.style.display = onPage ? '' : 'none';
		}

		if (pageIndicator instanceof HTMLElement) {
			pageIndicator.textContent = `${currentPage}/${totalPages}`;
		}
		if (prevButton instanceof HTMLButtonElement) prevButton.disabled = currentPage <= 1;
		if (nextButton instanceof HTMLButtonElement) nextButton.disabled = currentPage >= totalPages;
	};

	const applyFilters = () => {
		const categoryValue = categoryFilter instanceof HTMLSelectElement ? categoryFilter.value : 'All';
		const tagValue = tagFilter instanceof HTMLSelectElement ? tagFilter.value : 'All';
		currentPage = 1;

		for (const card of cards) {
			const cardCategory = card.getAttribute('data-category') ?? 'All';
			const cardTags = card.getAttribute('data-tags')?.split(',') ?? [];
			const categoryMatch = categoryValue === 'All' || cardCategory === categoryValue;
			const tagMatch = tagValue === 'All' || cardTags.includes(tagValue);
			card.toggleAttribute('hidden', !(categoryMatch && tagMatch));
			card.style.display = '';
		}

		applyPagination();
	};

	categoryFilter?.addEventListener('change', applyFilters);
	tagFilter?.addEventListener('change', applyFilters);
	prevButton?.addEventListener('click', () => {
		currentPage -= 1;
		applyPagination();
	});
	nextButton?.addEventListener('click', () => {
		currentPage += 1;
		applyPagination();
	});
	applyFilters();
</script>

<style>
	.filters {
		display: flex;
		gap: var(--space-4);
		margin-block: var(--space-4);
		flex-wrap: wrap;
	}

	label {
		display: grid;
		gap: 0.35rem;
		font-size: 0.85rem;
	}

	.articles-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--space-4);
	}

	.pager {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: var(--space-3);
		margin-top: var(--space-4);
	}

	.pager span {
		font-size: 0.85rem;
		color: color-mix(in srgb, var(--color-text) 55%, transparent);
	}
</style>
