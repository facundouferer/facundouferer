---
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';
import ProjectCard from './ProjectCard.astro';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;
const t = useTranslations(locale);

const projects = (await getCollection('projects')).filter((item) => item.data.published);
const filters = ['All', 'Civic Tech', 'EdTech', 'Government', 'Tourism', 'Portfolio & Art'];

const title = t('catalog.projects.title');
const subtitle = t('catalog.projects.subtitle');
---

<section class="section">
	<div class="container">
		<h1 class="section-title">{title}</h1>
		<p class="section-subtitle">{subtitle}</p>
		<div class="filters" role="toolbar" aria-label="Project filters">
			{filters.map((filter) => <button type="button" class="tag tag-outline" data-filter={filter}>{filter}</button>)}
		</div>
		<div class="project-grid" id="project-grid">
			{
				projects.map((project) => (
					<div data-category={project.data.category}>
						<ProjectCard project={project.data} locale={locale} />
					</div>
				))
			}
		</div>
	</div>
</section>

<script>
	const toolbar = document.querySelector('.filters');
	if (toolbar) {
		const cards = Array.from(document.querySelectorAll('[data-category]'));
		toolbar.addEventListener('click', (event) => {
			const button = event.target;
			if (!(button instanceof HTMLButtonElement)) return;
			const filter = button.dataset.filter ?? 'All';

			for (const card of cards) {
				const category = card.getAttribute('data-category');
				const visible = filter === 'All' || category === filter;
				card.toggleAttribute('hidden', !visible);
			}
		});
	}
</script>

<style>
	.filters {
		display: flex;
		gap: var(--space-2);
		flex-wrap: wrap;
		margin: var(--space-4) 0;
	}

	.filters button {
		cursor: pointer;
		font-family: var(--font-body);
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--space-4);
	}
</style>
