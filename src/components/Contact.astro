---
import { SOCIAL_LINKS } from '../config/site';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;
const copy = {
	es: {
		tag: 'CONTACTO',
		title: 'Listo para construir',
		titleAccent: 'el futuro?',
		subtitle: 'Acepto proyectos de alto impacto para 2025. Hablemos de tu vision con ingenieria de precision.',
		name: 'Tu nombre',
		email: 'Email',
		project: 'Descripcion del proyecto',
		submit: 'Enviar mensaje',
	},
	en: {
		tag: 'CONTACT',
		title: 'Ready to build',
		titleAccent: 'the future?',
		subtitle: 'Accepting high-impact projects for 2025. Let us discuss your vision with precision engineering.',
		name: 'Your Name',
		email: 'Email',
		project: 'Project description',
		submit: 'Send Message',
	},
}[locale];
---

<section class="section contact-section" id="contact">
	<div class="contact-glow" aria-hidden="true"></div>
	<div class="container">
		<div class="contact-header">
			<p class="contact-tag">{copy.tag}</p>
			<h2 class="section-title">
				{copy.title}{' '}
				<span class="gradient-text">{copy.titleAccent}</span>
			</h2>
			<p class="section-subtitle">{copy.subtitle}</p>
		</div>
		<div class="contact-grid">
			<form class="contact-form" method="post" action={`mailto:${SOCIAL_LINKS.email.replace('mailto:', '')}`}>
				<div class="form-row">
					<label>
						<span>{copy.name}</span>
						<input required name="name" type="text" />
					</label>
					<label>
						<span>{copy.email}</span>
						<input required name="email" type="email" />
					</label>
				</div>
				<label>
					<span>{copy.project}</span>
					<textarea required name="project" rows="4"></textarea>
				</label>
				<button type="submit">{copy.submit}</button>
			</form>
			<div class="contact-info">
				<div class="info-card">
					<span class="info-icon">📧</span>
					<a href={SOCIAL_LINKS.email}>{SOCIAL_LINKS.email.replace('mailto:', '')}</a>
				</div>
				<div class="social-links">
					<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
					<a href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">GitHub</a>
					<a href={SOCIAL_LINKS.twitter} target="_blank" rel="noreferrer">Twitter/X</a>
				</div>
			</div>
		</div>
	</div>
</section>

<footer class="site-footer">
	<div class="container footer-inner">
		<a href={locale === 'es' ? '/' : '/en/'} class="footer-brand">
			<span class="fb-accent">FACUNDO</span><span class="fb-dim">UFERER</span>
		</a>
		<p class="footer-copy">© {new Date().getFullYear()} Facundo Uferer. {locale === 'es' ? 'Hecho con precision.' : 'Built with precision.'}</p>
	</div>
</footer>

<style>
	.contact-section {
		padding-bottom: 3rem;
		position: relative;
		overflow: hidden;
	}

	.contact-section::after {
		display: none;
	}

	.contact-glow {
		position: absolute;
		top: 20%;
		left: 50%;
		transform: translateX(-50%);
		width: 600px;
		height: 400px;
		background: radial-gradient(
			ellipse,
			rgb(6 182 212 / 10%) 0%,
			rgb(168 85 247 / 6%) 40%,
			transparent 70%
		);
		pointer-events: none;
		z-index: 0;
	}

	.contact-header {
		text-align: center;
		margin-bottom: 2.5rem;
	}

	.contact-header .section-subtitle {
		margin-inline: auto;
	}

	.contact-tag {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-cyan);
		margin: 0 0 0.6rem;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 2rem;
		align-items: start;
	}

	.contact-form {
		padding: 1.6rem;
		display: grid;
		gap: 1rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 1.2rem;
		backdrop-filter: blur(12px);
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	label {
		display: grid;
		gap: 0.4rem;
		font-size: 0.85rem;
		color: var(--color-muted);
	}

	label span {
		font-family: var(--font-mono);
		font-size: 0.74rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	input,
	textarea {
		width: 100%;
		padding: 0.7rem 0.9rem;
		background: rgb(255 255 255 / 3%);
		border: 1px solid var(--color-border);
		border-radius: 0.6rem;
		color: var(--color-text);
		font-family: var(--font-body);
		font-size: 0.9rem;
		transition: border-color 200ms ease;
	}

	input:focus,
	textarea:focus {
		outline: none;
		border-color: var(--color-accent);
	}

	button {
		width: 100%;
		padding: 0.85rem;
		border: none;
		border-radius: 0.6rem;
		font-weight: 700;
		font-size: 0.88rem;
		background: var(--grad-accent);
		color: #fff;
		cursor: pointer;
		transition: transform 200ms ease, box-shadow 200ms ease;
		letter-spacing: 0.02em;
	}

	button:hover {
		transform: translateY(-1px);
		box-shadow: 0 4px 20px rgb(168 85 247 / 30%);
	}

	.contact-info {
		display: grid;
		gap: 1.2rem;
		align-content: start;
	}

	.info-card {
		padding: 1.2rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 1rem;
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.info-icon {
		font-size: 1.2rem;
	}

	.info-card a {
		color: var(--color-cyan);
		text-decoration: none;
		font-size: 0.88rem;
		word-break: break-all;
	}

	.social-links {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.social-links a {
		padding: 0.5rem 1rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.8rem;
		color: var(--color-muted);
		transition: color 200ms ease, border-color 200ms ease;
	}

	.social-links a:hover {
		color: var(--color-text);
		border-color: var(--color-accent);
	}

	/* Footer */
	.site-footer {
		padding: 2rem 0;
		border-top: 1px solid var(--color-border);
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.footer-brand {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 0.9rem;
		letter-spacing: 0.06em;
		text-decoration: none;
	}

	.fb-accent {
		color: var(--color-cyan);
	}

	.fb-dim {
		color: var(--color-muted);
	}

	.footer-copy {
		margin: 0;
		font-size: 0.78rem;
		color: var(--color-muted);
	}

	@media (width < 760px) {
		.contact-grid {
			grid-template-columns: 1fr;
		}

		.form-row {
			grid-template-columns: 1fr;
		}
	}
</style>
