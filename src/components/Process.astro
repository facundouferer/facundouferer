---
type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const content = {
	es: {
		title: 'De la idea a produccion',
		subtitle: 'Proceso de desarrollo acelerado con IA.',
		steps: [
			{ num: '01', name: 'Descubrir', desc: 'Entender el problema real detras del requerimiento.' },
			{ num: '02', name: 'Disenar', desc: 'Arquitectura solida antes de escribir una linea.' },
			{ num: '03', name: 'Construir', desc: 'Multi-agentes trabajando bajo tu direccion.' },
			{ num: '04', name: 'Desplegar', desc: 'CI/CD, monitoreo y mejora continua.' },
		],
	},
	en: {
		title: 'From idea to production',
		subtitle: 'AI-accelerated development process.',
		steps: [
			{ num: '01', name: 'Discover', desc: 'Understand the real problem behind the requirement.' },
			{ num: '02', name: 'Design', desc: 'Solid architecture before writing a single line.' },
			{ num: '03', name: 'Build', desc: 'Multi-agent systems working under your direction.' },
			{ num: '04', name: 'Deploy', desc: 'CI/CD, monitoring, and continuous improvement.' },
		],
	},
}[locale];
---

<section class="section">
	<div class="container">
		<h2 class="section-title">
			{content.title.split(' ').slice(0, -1).join(' ')}{' '}
			<span class="accent-word">{content.title.split(' ').at(-1)}</span>
		</h2>
		<p class="section-subtitle">{content.subtitle}</p>
		<ol class="steps">
			{
				content.steps.map((step) => (
					<li class="step-item">
						<span class="step-num">{step.num}</span>
						<div class="step-content">
							<strong>{step.name}</strong>
							<p>{step.desc}</p>
						</div>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	.steps {
		list-style: none;
		padding: 0;
		margin: var(--space-6) 0 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: var(--space-4);
	}

	.step-item {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding: var(--space-4);
		background: var(--color-surface);
		border-radius: calc(var(--radius-lg) * 1.15);
		transition: transform 220ms ease, box-shadow 220ms ease;
	}

	.step-item:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
	}

	.step-num {
		font-family: var(--font-heading);
		font-weight: var(--font-heading-weight);
		font-size: 2.4rem;
		line-height: 1;
		color: var(--color-accent);
	}

	.step-content {
		display: grid;
		gap: 0.3rem;
	}

	.step-content strong {
		font-family: var(--font-heading);
		font-weight: var(--font-heading-weight);
		font-size: 1.1rem;
	}

	.step-content p {
		margin: 0;
		color: color-mix(in srgb, var(--color-text) 78%, transparent);
		font-size: 0.9rem;
		line-height: 1.55;
	}
</style>
