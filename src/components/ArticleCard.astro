---
import { withBase } from '../utils/withBase';

type Article = {
	title: string;
	title_en: string;
	slug: string;
	date: Date;
	category: string;
	tags: string[];
	excerpt: string;
	excerpt_en: string;
	readingTime: number;
	image?: string;
	lang: 'es' | 'en' | 'both';
};

type Props = {
	article: Article;
	locale: 'es' | 'en';
};

const { article, locale } = Astro.props;
const title = locale === 'es' ? article.title : article.title_en;
const excerpt = locale === 'es' ? article.excerpt : article.excerpt_en;
const href = locale === 'es' ? `/articulos/${article.slug}` : `/en/articles/${article.slug}`;
const dateLabel = article.date.toLocaleDateString(locale === 'es' ? 'es-AR' : 'en-US');
---

<article class="article-card" data-category={article.category} data-tags={article.tags.join(',')}>
	{article.image && (
		<a href={withBase(href)} class="article-card-image">
			<img src={withBase(article.image)} alt={title} loading="lazy" />
		</a>
	)}
	<div class="card-top">
		<span class="category-pill">{article.category}</span>
		<span class="reading-time">{article.readingTime} min</span>
	</div>
	<h3><a href={withBase(href)}>{title}</a></h3>
	<p class="excerpt">{excerpt}</p>
	<div class="card-footer">
		<span class="date">{dateLabel}</span>
		<ul class="tags">
			{article.tags.slice(0, 3).map((tag) => <li>{tag}</li>)}
		</ul>
	</div>
	{article.lang !== 'both' && <p class="lang-tag">{locale === 'es' ? `Idioma: ${article.lang}` : `Language: ${article.lang}`}</p>}
</article>

<style>
	.article-card {
		overflow: hidden;
		display: grid;
		gap: 0.7rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 1rem;
		transition: transform 250ms ease, border-color 250ms ease;
	}

	.article-card:hover {
		transform: translateY(-4px);
		border-color: rgb(6 182 212 / 30%);
	}

	.article-card-image {
		display: block;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-bottom: 1px solid var(--color-border);
	}

	.article-card-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 250ms ease;
	}

	.article-card:hover .article-card-image img {
		transform: scale(1.03);
	}

	.card-top,
	h3,
	.excerpt,
	.card-footer,
	.lang-tag {
		padding-inline: 1.4rem;
	}

	.card-top {
		padding-top: 0.7rem;
	}

	.lang-tag {
		padding-bottom: 1.2rem;
	}

	.card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.category-pill {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		background: rgb(6 182 212 / 10%);
		border: 1px solid rgb(6 182 212 / 20%);
		color: var(--color-cyan);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.reading-time {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--color-muted);
	}

	h3 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.1rem;
	}

	h3 a {
		text-decoration: none;
		color: var(--color-text);
		transition: color 200ms ease;
	}

	h3 a:hover {
		color: var(--color-cyan);
	}

	.excerpt {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		margin-top: 0.2rem;
	}

	.date {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--color-muted);
	}

	.tags {
		display: flex;
		gap: 0.3rem;
		padding: 0;
		margin: 0;
		list-style: none;
		flex-wrap: wrap;
	}

	.tags li {
		font-family: var(--font-mono);
		font-size: 0.68rem;
		padding: 0.15rem 0.4rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		color: var(--color-muted);
	}

	.lang-tag {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--color-muted);
	}
</style>
