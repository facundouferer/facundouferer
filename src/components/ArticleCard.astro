---
import { withBase } from '../utils/withBase';

type Article = {
	title: string;
	title_en: string;
	slug: string;
	date: Date;
	category: string;
	tags: string[];
	excerpt: string;
	excerpt_en: string;
	readingTime: number;
	image?: string;
	lang: 'es' | 'en' | 'both';
};

type Props = {
	article: Article;
	locale: 'es' | 'en';
};

const { article, locale } = Astro.props;
const title = locale === 'es' ? article.title : article.title_en;
const excerpt = locale === 'es' ? article.excerpt : article.excerpt_en;
const href = locale === 'es' ? `/articulos/${article.slug}` : `/en/articles/${article.slug}`;
const dateLabel = article.date.toLocaleDateString(locale === 'es' ? 'es-AR' : 'en-US');
---

<article class="article-card card card-hover" data-category={article.category} data-tags={article.tags.join(',')}>
	{article.image && (
		<a href={withBase(href)} class="article-card-image washed">
			<img src={withBase(article.image)} alt={title} loading="lazy" />
		</a>
	)}
	<div class="card-top">
		<span class="tag tag-accent">{article.category}</span>
		<span class="reading-time">
			<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
			{article.readingTime} min
		</span>
	</div>
	<h3 class="card-title"><a href={withBase(href)}>{title}</a></h3>
	<p class="card-body">{excerpt}</p>
	<div class="card-footer">
		<span class="date">{dateLabel}</span>
		<ul class="tags">
			{article.tags.slice(0, 3).map((tag) => <li class="tag tag-neutral">{tag}</li>)}
		</ul>
	</div>
	{article.lang !== 'both' && <p class="lang-tag">{locale === 'es' ? `Idioma: ${article.lang}` : `Language: ${article.lang}`}</p>}
</article>

<style>
	.article-card {
		overflow: hidden;
		padding: 0;
		display: grid;
		gap: var(--space-2);
	}

	.article-card-image {
		display: block;
		aspect-ratio: 16 / 9;
		overflow: hidden;
	}

	.article-card-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 300ms ease;
	}

	.article-card:hover .article-card-image img {
		transform: scale(1.03);
	}

	.card-top,
	.card-title,
	.card-body,
	.card-footer,
	.lang-tag {
		padding-inline: var(--space-4);
	}

	.card-top {
		padding-top: var(--space-4);
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.card-body {
		font-size: 0.9rem;
	}

	.lang-tag {
		padding-bottom: var(--space-4);
		margin: 0;
		font-size: 0.75rem;
		color: color-mix(in srgb, var(--color-text) 55%, transparent);
	}

	.reading-time {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-size: 0.75rem;
		color: color-mix(in srgb, var(--color-text) 55%, transparent);
	}

	.reading-time svg {
		width: 13px;
		height: 13px;
		fill: none;
		stroke: currentColor;
		stroke-width: 2.75;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.card-title a {
		text-decoration: none;
		color: var(--color-text);
	}

	.card-title a:hover {
		color: var(--color-accent-700);
	}

	.card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-2);
		margin-top: 0.2rem;
	}

	.date {
		font-size: 0.75rem;
		color: color-mix(in srgb, var(--color-text) 55%, transparent);
	}

	.tags {
		display: flex;
		gap: 0.3rem;
		padding: 0;
		margin: 0;
		list-style: none;
		flex-wrap: wrap;
	}
</style>
