---
type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const title = locale === 'es' ? 'El Arsenal' : 'The Toolchain';
const subtitle =
	locale === 'es'
		? 'Herramientas modernas para productos robustos y a prueba de futuro.'
		: 'Leveraging modern primitives to build robust, future-proof digital products.';

const stacks = [
	{
		icon: '🤖',
		title: locale === 'es' ? 'Ingenieria IA' : 'AI Engineering',
		items: 'Claude Code, Cursor, Copilot, Gemini, Codex, n8n',
		accent: 'var(--color-magenta)',
	},
	{
		icon: '🎨',
		title: 'Frontend',
		items: 'React, Next.js, Svelte, Vue.js, Astro, TypeScript, Tailwind CSS',
		accent: 'var(--color-accent)',
	},
	{
		icon: '⚙️',
		title: locale === 'es' ? 'Backend & Core' : 'Backend & Core',
		items: 'Node.js, NestJS, PostgreSQL, MongoDB, MySQL, REST, GraphQL',
		accent: 'var(--color-cyan)',
	},
	{
		icon: '☁️',
		title: 'Cloud & DevOps',
		items: 'AWS, Vercel, Cloud Run, Docker, Linux Servers, CI/CD',
		accent: '#59d6f5',
	},
];
---

<section class="section">
	<div class="container">
		<p class="section-tag">{locale === 'es' ? 'TECNOLOGIA' : 'TECHNOLOGY'}</p>
		<h2 class="section-title">
			{locale === 'es' ? 'El ' : 'The '}
			<span class="gradient-text">{locale === 'es' ? 'Arsenal' : 'Toolchain'}</span>
		</h2>
		<p class="section-subtitle">{subtitle}</p>
		<div class="stack-grid">
			{
				stacks.map((stack) => (
					<article class="stack-card" style={`--card-accent: ${stack.accent}`}>
						<div class="stack-icon">{stack.icon}</div>
						<h3>{stack.title}</h3>
						<p>{stack.items}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.section-tag {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-cyan);
		margin: 0 0 0.6rem;
	}

	.stack-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1.2rem;
		margin-top: 2rem;
	}

	.stack-card {
		padding: 1.6rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 1rem;
		position: relative;
		overflow: hidden;
		transition: transform 250ms ease, border-color 250ms ease;
	}

	.stack-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: var(--card-accent);
		opacity: 0.8;
	}

	.stack-card:hover {
		transform: translateY(-4px);
		border-color: var(--card-accent);
	}

	.stack-icon {
		font-size: 1.5rem;
		margin-bottom: 0.8rem;
		width: 2.6rem;
		height: 2.6rem;
		display: grid;
		place-items: center;
		border-radius: 0.5rem;
		background: rgb(255 255 255 / 4%);
	}

	.stack-card h3 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.05rem;
	}

	.stack-card p {
		margin: 0.5rem 0 0;
		color: var(--color-muted);
		font-size: 0.88rem;
		line-height: 1.6;
	}
</style>
