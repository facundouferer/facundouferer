---
import { useTranslations } from '../i18n/utils';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;
const t = useTranslations(locale);

const subtitle = t('toolchain.subtitle');

const stacks = [
	{
		icon: 'bot',
		title: t('toolchain.stack.ai'),
		items: 'Claude Code, Cursor, Copilot, Gemini, Codex, n8n',
		accent2: false,
	},
	{
		icon: 'palette',
		title: 'Frontend',
		items: 'React, Next.js, Svelte, Vue.js, Astro, TypeScript, Tailwind CSS',
		accent2: true,
	},
	{
		icon: 'settings',
		title: t('toolchain.stack.backend'),
		items: 'Node.js, NestJS, PostgreSQL, MongoDB, MySQL, REST, GraphQL',
		accent2: false,
	},
	{
		icon: 'cloud',
		title: 'Cloud & DevOps',
		items: 'AWS, Vercel, Cloud Run, Docker, Linux Servers, CI/CD',
		accent2: true,
	},
];

const icons: Record<string, string> = {
	bot: '<path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>',
	palette:
		'<circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>',
	settings:
		'<path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"/>',
	cloud: '<path d="M17.5 19H9a7 7 0 1 1 6.71-9h.79a4.5 4.5 0 1 1 0 9Z"/>',
};
---

<section class="section">
	<div class="container">
		<p class="kicker">{t('toolchain.kicker')}</p>
		<h2 class="section-title">
			{t('toolchain.titleStart')}{' '}
			<span class="accent-word">{t('toolchain.titleAccent')}</span>
		</h2>
		<p class="section-subtitle">{subtitle}</p>
		<div class="stack-grid">
			{
				stacks.map((stack) => (
					<article class="card card-hover">
						<span class:list={['card-icon', { 'accent-2': stack.accent2 }]} set:html={icons[stack.icon]} />
						<h3 class="card-title">{stack.title}</h3>
						<p class="card-body">{stack.items}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.stack-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: var(--space-4);
		margin-top: var(--space-6);
	}

	.card svg {
		width: 20px;
		height: 20px;
		fill: none;
		stroke: currentColor;
		stroke-width: 2.75;
		stroke-linecap: round;
		stroke-linejoin: round;
	}
</style>
