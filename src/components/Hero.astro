---
import { withBase } from '../utils/withBase';

type Props = { locale: 'es' | 'en' };
const { locale } = Astro.props;

const content = {
	es: {
		titleStart: 'Software listo para',
		titleAccent: 'produccion',
		titleEnd: 'a la velocidad del pensamiento.',
		subtitle:
			'',
		primary: 'Ver Proyectos',
		secondary: 'Hablemos',
		badge: 'Disponible para nuevos proyectos',
		projectsHref: '/proyectos',
	},
	en: {
		titleStart: 'Building production-ready',
		titleAccent: 'software',
		titleEnd: 'at the speed of thought.',
		subtitle:
			'',
		primary: 'View Projects',
		secondary: "Let's Talk",
		badge: 'Available for new projects',
		projectsHref: '/en/projects',
	},
}[locale];

const contactHref = locale === 'es' ? '/#contact' : '/en/#contact';
---

<section class="section hero-section">
	<div class="hero-glow" aria-hidden="true"></div>
	<div class="container hero-shell">
		<p class="hero-pill">{content.badge}</p>
		<h1 class="hero-title">
			{content.titleStart}
			<span class="hero-gradient"> {content.titleAccent} </span>
			{content.titleEnd}
		</h1>
		{content.subtitle && <p class="hero-subtitle">{content.subtitle}</p>}
		<div class="hero-actions">
			<a class="hero-cta hero-cta-primary" href={withBase(content.projectsHref)}>{content.primary}</a>
			<a class="hero-cta hero-cta-secondary" href={withBase(contactHref)}>{content.secondary}</a>
		</div>
	</div>
	<span class="hero-underline" aria-hidden="true"></span>
</section>

<style>
	.hero-section {
		padding-top: clamp(2.4rem, 6vw, 5rem);
		padding-bottom: clamp(2rem, 5vw, 4rem);
		overflow: hidden;
	}

	.hero-section::after {
		display: none;
	}

	.hero-glow {
		position: absolute;
		top: -20%;
		left: 50%;
		transform: translateX(-50%);
		width: 800px;
		height: 500px;
		background: radial-gradient(
			ellipse,
			rgb(168 85 247 / 15%) 0%,
			rgb(6 182 212 / 8%) 40%,
			transparent 70%
		);
		pointer-events: none;
		animation: pulse-glow 6s ease-in-out infinite;
	}

	.hero-shell {
		position: relative;
		text-align: center;
		display: grid;
		gap: 1.4rem;
		justify-items: center;
	}

	.hero-pill {
		margin: 0;
		padding: 0.4rem 1rem;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #59d6f5;
		border: 1px solid rgb(89 214 245 / 30%);
		background: rgb(89 214 245 / 8%);
		border-radius: 999px;
		animation: fadeInUp 600ms ease both;
	}

	.hero-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(2.6rem, 7.5vw, 6.2rem);
		line-height: 1.02;
		letter-spacing: -0.035em;
		max-width: 18ch;
		animation: fadeInUp 600ms ease 100ms both;
	}

	.hero-gradient {
		background: var(--grad-primary);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		position: relative;
		filter: drop-shadow(0 0 12px color-mix(in srgb, var(--color-magenta) 50%, transparent))
		        drop-shadow(0 0 25px color-mix(in srgb, var(--color-cyan) 30%, transparent));
		animation: gradient-pulse 3s ease-in-out infinite alternate;
	}

	@keyframes gradient-pulse {
		from {
			filter: drop-shadow(0 0 10px color-mix(in srgb, var(--color-magenta) 40%, transparent))
			        drop-shadow(0 0 20px color-mix(in srgb, var(--color-cyan) 20%, transparent));
		}
		to {
			filter: drop-shadow(0 0 16px color-mix(in srgb, var(--color-magenta) 70%, transparent))
			        drop-shadow(0 0 32px color-mix(in srgb, var(--color-cyan) 50%, transparent));
		}
	}

	.hero-gradient::after {
		content: '';
		position: absolute;
		bottom: 0.05em;
		left: 0;
		right: 0;
		height: 3px;
		background: var(--grad-primary);
		border-radius: 999px;
		opacity: 0.5;
	}

	.hero-subtitle {
		margin: 0;
		max-width: 52ch;
		font-size: clamp(1rem, 2vw, 1.25rem);
		color: var(--color-muted);
		line-height: 1.7;
		animation: fadeInUp 600ms ease 200ms both;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		justify-content: center;
		animation: fadeInUp 600ms ease 300ms both;
	}

	.hero-cta {
		padding: 0.9rem 1.8rem;
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.8rem;
		font-family: var(--font-mono);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		border: 1px solid var(--color-border);
		transition: transform 200ms ease, box-shadow 200ms ease;
	}

	.hero-cta:hover {
		transform: translateY(-2px);
	}

	.hero-cta-primary {
		background: var(--grad-accent);
		color: #fff;
		border: none;
		box-shadow: 0 4px 24px rgb(168 85 247 / 20%);
	}

	.hero-cta-primary:hover {
		box-shadow: 0 6px 32px rgb(168 85 247 / 35%);
	}

	.hero-cta-secondary {
		background: rgb(255 255 255 / 4%);
		color: var(--color-text);
		backdrop-filter: blur(8px);
	}

	.hero-cta-secondary:hover {
		background: rgb(255 255 255 / 8%);
	}

	.hero-underline {
		display: block;
		width: min(50vw, 480px);
		height: 3px;
		margin: 1.5rem auto 0;
		border-radius: 999px;
		background: linear-gradient(90deg, transparent, var(--color-cyan), var(--color-accent), transparent);
		opacity: 0.6;
	}

</style>
