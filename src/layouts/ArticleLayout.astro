---
import BaseLayout from './BaseLayout.astro';
import { buildArticleSchemas } from '../seo/schema';
import { withBase } from '../utils/withBase';
import { useTranslations } from '../i18n/utils';
import { AUTHOR } from '../config/site';

type ArticleData = {
	title: string;
	category: string;
	author: string;
	tags: string[];
	date: Date;
	readingTime: number;
	image?: string;
};

type LinkInfo = {
	title: string;
	href: string;
} | null;

type Props = {
	locale: 'es' | 'en';
	article: ArticleData;
	href: string;
	prev: LinkInfo;
	next: LinkInfo;
	contentDescription: string;
	ocImage?: string;
};

const { locale, article, href, prev, next, contentDescription, ocImage } = Astro.props;
const t = useTranslations(locale);
const title = article.title;
const contactHref = locale === 'es' ? '/#contact' : '/en/#contact';
const dateText = article.date.toLocaleDateString(locale === 'es' ? 'es-AR' : 'en-US');
const schema = buildArticleSchemas({
	locale,
	path: href,
	title,
	description: contentDescription,
	datePublished: article.date,
	image: article.image ?? ocImage,
	category: article.category,
	tags: article.tags,
});
---

<BaseLayout
	title={title}
	description={contentDescription}
	locale={locale}
	esPath={locale === 'es' ? href : href.replace('/en/articles/', '/articulos/')}
	enPath={locale === 'en' ? href : href.replace('/articulos/', '/en/articles/')}
	canonicalPath={href}
	ogType="article"
	ocImage={ocImage}
	schema={schema}
	publishedTime={article.date.toISOString()}
	modifiedTime={article.date.toISOString()}
	articleTags={article.tags}
	section={article.category}
>
	<article class="section article-wrap">
		<div class="container article-shell">
			<header>
				<p class="tag tag-accent">{article.category}</p>
				<h1 class="section-title">{title}</h1>
				<p class="meta">
					{article.author} · {dateText} · {article.readingTime} min
				</p>
				<p class="meta">Tags: {article.tags.join(' · ')}</p>
			</header>
			<div class="article-body">
				<slot />
			</div>
			<footer class="article-footer">
				<div class="author-box card">
					<img src={withBase('/foto_facundo_02.png')} alt="Facundo Uferer" loading="lazy" />
					<div>
						<strong>Facundo Uferer</strong>
						<p>{AUTHOR.jobTitle[locale]}</p>
					</div>
				</div>
				<nav class="pager" aria-label="Article navigation">
					{prev && <a class="btn btn-secondary" href={withBase(prev.href)}>← {prev.title}</a>}
					{next && <a class="btn btn-secondary" href={withBase(next.href)}>{next.title} →</a>}
				</nav>
				<p>
					<a class="btn btn-ghost" href={withBase(contactHref)}>{t('article.ctaWorkTogether')}</a>
				</p>
			</footer>
		</div>
	</article>
</BaseLayout>

<style>
	.article-shell {
		max-width: 1024px;
	}

	.meta {
		margin: 0;
		color: color-mix(in srgb, var(--color-text) 55%, transparent);
		font-size: 0.85rem;
	}

	.article-body {
		font-size: 1.05rem;
		line-height: 1.8;
		margin-top: var(--space-4);
		text-align: justify;
	}

	.article-body :global(h1),
	.article-body :global(h2),
	.article-body :global(h3),
	.article-body :global(h4) {
		font-family: var(--font-heading);
		font-weight: var(--font-heading-weight);
		line-height: 1.2;
		letter-spacing: -0.015em;
		margin: 1.5em 0 0.45em;
		color: var(--color-text);
	}

	.article-body :global(h1) {
		font-size: clamp(1.8rem, 4vw, 2.4rem);
	}

	.article-body :global(h2) {
		font-size: clamp(1.55rem, 3.4vw, 2rem);
	}

	.article-body :global(h3) {
		font-size: clamp(1.3rem, 2.8vw, 1.6rem);
	}

	.article-body :global(p),
	.article-body :global(ul),
	.article-body :global(ol) {
		margin: 0 0 1rem;
	}

	.article-body :global(ul) {
		list-style: disc;
		padding-left: 1.5rem;
	}

	.article-body :global(ol) {
		list-style: decimal;
		padding-left: 1.5rem;
	}

	.article-body :global(li) {
		margin: 0 0 0.45rem;
	}

	.article-body :global(a) {
		color: var(--color-accent-700);
	}

	.article-body :global(strong) {
		color: var(--color-accent-700);
		font-weight: 700;
	}

	.article-body :global(img) {
		display: block;
		float: right;
		width: min(48%, 320px);
		height: auto;
		margin: 0 0 1rem 1.5rem;
		border-radius: var(--radius-lg);
		shape-margin: 1rem;
	}

	.article-body :global(p:has(> img)) {
		margin: 0;
	}

	.article-body :global(h1),
	.article-body :global(h2),
	.article-body :global(h3),
	.article-body :global(h4),
	.article-body :global(pre),
	.article-body :global(blockquote) {
		clear: both;
	}

	.article-body :global(pre) {
		overflow-x: auto;
		padding: var(--space-4);
		border-radius: var(--radius-md);
		background: var(--color-surface);
	}

	.article-body :global(blockquote) {
		margin: 0;
		padding-left: var(--space-4);
		border-left: 3px solid var(--color-accent);
		color: color-mix(in srgb, var(--color-text) 78%, transparent);
	}

	.article-body :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 1.5rem 0;
	}

	.article-body :global(th),
	.article-body :global(td) {
		border-bottom: 1px solid var(--color-divider);
		padding: var(--space-2) var(--space-3);
		text-align: left;
	}

	.article-body :global(th) {
		color: var(--color-accent-700);
		font-family: var(--font-heading);
		font-weight: var(--font-heading-weight);
		border-bottom: 2px solid var(--color-accent);
	}

	.article-footer {
		margin-top: var(--space-8);
		padding-top: var(--space-4);
	}

	.author-box {
		flex-direction: row;
		padding: var(--space-3);
		display: flex;
		gap: var(--space-3);
		align-items: center;
		margin-bottom: var(--space-4);
	}

	.author-box img {
		width: 52px;
		height: 52px;
		border-radius: 999px;
		object-fit: cover;
	}

	.author-box p {
		margin: 0.2rem 0 0;
		color: color-mix(in srgb, var(--color-text) 70%, transparent);
		font-size: 0.88rem;
	}

	.pager {
		display: flex;
		justify-content: space-between;
		gap: var(--space-2);
		flex-wrap: wrap;
	}

	@media (width < 760px) {
		.article-body :global(img) {
			float: none;
			width: 100%;
			margin: 0 0 1.25rem;
		}

		.article-body :global(p:has(> img)) {
			margin: 0 0 1rem;
		}
	}
</style>
